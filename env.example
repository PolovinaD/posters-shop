# ============================================================
# PosterShop Platform - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp env.example .env
# ============================================================

# =========================
# AWS Configuration
# =========================
AWS_PROFILE=private
AWS_ACCOUNT_ID=123456789012
AWS_REGION=eu-north-1

# Derived values (auto-computed if not set)
# ECR_REGISTRY=${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com

# =========================
# Kubernetes / EKS
# =========================
CLUSTER_NAME=postershop
NAMESPACE=postershop

# =========================
# Database (Local Development)
# =========================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=posters_shop

# Service-specific database URLs (for docker-compose)
# These use the schema-per-service pattern
USERS_DATABASE_URL=postgresql://users_svc:users_pass@db:5432/posters_shop
CATALOG_DATABASE_URL=postgresql://catalog_svc:catalog_pass@db:5432/posters_shop
ORDERS_DATABASE_URL=postgresql://orders_svc:orders_pass@db:5432/posters_shop
PRODUCTION_DATABASE_URL=postgresql://production_svc:production_pass@db:5432/posters_shop
LOGISTICS_DATABASE_URL=postgresql://logistics_svc:logistics_pass@db:5432/posters_shop
INVENTORY_DATABASE_URL=postgresql://inventory_svc:inventory_pass@db:5432/posters_shop

# =========================
# Authentication
# =========================
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# =========================
# CORS
# =========================
CORS_ORIGINS=http://localhost:3000

# =========================
# Circuit Breaker
# =========================
CB_FAILURE_THRESHOLD=5
CB_RECOVERY_TIMEOUT=30

# =========================
# Stripe (Payment Mock)
# =========================
STRIPE_WEBHOOK_SECRET=whsec_test_secret_key_12345

# =========================
# GitHub Actions (for reference)
# =========================
# Set these as repository variables in GitHub:
# - AWS_ACCOUNT_ID
# - AWS_REGION  
# - EKS_CLUSTER
#
# Set these as repository secrets in GitHub:
# - (OIDC handles authentication, no secrets needed for AWS)

# =========================
# Service URLs (for inter-service communication)
# =========================
INVENTORY_SERVICE_URL=http://inventory:8000
PRODUCTION_SERVICE_URL=http://production:8000
LOGISTICS_SERVICE_URL=http://logistics:8000
ORDERS_SERVICE_URL=http://orders:8000
PAYMENT_SERVICE_URL=http://payments:8000

