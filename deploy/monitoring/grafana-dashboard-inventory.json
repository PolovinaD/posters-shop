{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "row",
      "title": "Stock Overview",
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Total SKUs",
      "targets": [
        {"expr": "count(inventory_stock_level)", "legendFormat": "SKUs"}
      ],
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "short"}
      },
      "gridPos": {"x": 0, "y": 1, "w": 4, "h": 4}
    },
    {
      "type": "stat",
      "title": "Total Stock",
      "targets": [
        {"expr": "sum(inventory_stock_level)", "legendFormat": "Units"}
      ],
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "short"}
      },
      "gridPos": {"x": 4, "y": 1, "w": 4, "h": 4}
    },
    {
      "type": "stat",
      "title": "Low Stock Items",
      "targets": [
        {"expr": "count(inventory_stock_level < 10)", "legendFormat": "Low"}
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 3},
              {"color": "red", "value": 5}
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {"x": 8, "y": 1, "w": 4, "h": 4}
    },
    {
      "type": "stat",
      "title": "Active Reservations",
      "targets": [
        {"expr": "inventory_active_reservations", "legendFormat": "Active"}
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 50},
              {"color": "red", "value": 100}
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {"x": 12, "y": 1, "w": 4, "h": 4}
    },
    {
      "type": "stat",
      "title": "Reservations Expired (1h)",
      "targets": [
        {"expr": "sum(increase(inventory_reservations_expired_total[1h]))", "legendFormat": "Expired"}
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 5},
              {"color": "red", "value": 20}
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {"x": 16, "y": 1, "w": 4, "h": 4}
    },
    {
      "type": "stat",
      "title": "Out of Stock",
      "targets": [
        {"expr": "count(inventory_stock_level == 0)", "legendFormat": "OOS"}
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {"x": 20, "y": 1, "w": 4, "h": 4}
    },
    {
      "type": "row",
      "title": "Stock Levels",
      "gridPos": {"x": 0, "y": 5, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "type": "bargauge",
      "title": "Current Stock by SKU",
      "targets": [
        {"expr": "inventory_stock_level", "legendFormat": "{{sku}}"}
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 10},
              {"color": "green", "value": 30}
            ]
          },
          "unit": "short",
          "min": 0
        }
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "gridPos": {"x": 0, "y": 6, "w": 12, "h": 12}
    },
    {
      "type": "timeseries",
      "title": "Stock Levels Over Time",
      "targets": [
        {"expr": "inventory_stock_level", "legendFormat": "{{sku}}"}
      ],
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "short"}
      },
      "options": {"legend": {"displayMode": "table", "placement": "right"}},
      "gridPos": {"x": 12, "y": 6, "w": 12, "h": 12}
    },
    {
      "type": "row",
      "title": "Reservations",
      "gridPos": {"x": 0, "y": 18, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Active Reservations Over Time",
      "targets": [
        {"expr": "inventory_active_reservations", "legendFormat": "Active"}
      ],
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "short"}
      },
      "gridPos": {"x": 0, "y": 19, "w": 12, "h": 8}
    },
    {
      "type": "timeseries",
      "title": "Reservation Expiry Rate",
      "targets": [
        {"expr": "rate(inventory_reservations_expired_total[5m]) * 60", "legendFormat": "Expired/min"}
      ],
      "fieldConfig": {
        "defaults": {"color": {"fixedColor": "orange", "mode": "fixed"}, "unit": "short"}
      },
      "gridPos": {"x": 12, "y": 19, "w": 12, "h": 8}
    },
    {
      "type": "row",
      "title": "Service Performance",
      "gridPos": {"x": 0, "y": 27, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Inventory Service Requests",
      "targets": [
        {"expr": "sum(rate(http_requests_total{service=\"inventory\"}[5m])) by (path)", "legendFormat": "{{path}}"}
      ],
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "reqps"}
      },
      "gridPos": {"x": 0, "y": 28, "w": 12, "h": 8}
    },
    {
      "type": "timeseries",
      "title": "Inventory Service Latency",
      "targets": [
        {"expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{service=\"inventory\"}[5m])) by (le)) * 1000", "legendFormat": "P50"},
        {"expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{service=\"inventory\"}[5m])) by (le)) * 1000", "legendFormat": "P95"},
        {"expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{service=\"inventory\"}[5m])) by (le)) * 1000", "legendFormat": "P99"}
      ],
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "ms"}
      },
      "gridPos": {"x": 12, "y": 28, "w": 12, "h": 8}
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["postershop", "inventory"],
  "time": {"from": "now-1h", "to": "now"},
  "timezone": "browser",
  "title": "PosterShop Inventory",
  "uid": "postershop-inventory",
  "version": 1
}

